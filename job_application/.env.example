# .env.example
# Add your API keys and configuration here. Copy this file to .env

# LLM Providers (Choose one or both)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Scraping configuration or third-party API keys
# SCRAPER_API_KEY=your_scraper_api_key_here

# Applicant Profile details (for form filling if needed by agent)
APPLICANT_NAME="John Doe"
APPLICANT_EMAIL="john.doe@example.com"
APPLICANT_PHONE="123-456-7890"
APPLICANT_LINKEDIN="https://linkedin.com/in/johndoe"
APPLICANT_GITHUB="https://github.com/johndoe"